{
  "$schema": "https://turbo.build/schema.json",
  "ui": "stream",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", "src/gen/**"]
    },
    "typecheck": {
      "dependsOn": ["^build", "build"]
    },
    "lint": {},
    "test": {
      "dependsOn": ["^build", "build"],
      "outputs": ["coverage/**", "test-results/**"]
    }
  }
}
