    "@nestjs/swagger": "^11.4.4",
    "@nestjs/throttler": "^6.5.0",
    "@node-rs/argon2": "^2.0.2",
    "@resvg/resvg-js": "^2.6.2",
    "@trm/codec": "workspace:*",
    "@trm/engine": "workspace:*",
