# TRMission server
PORT=3001

# MongoDB (Step B persistence). Start one with: docker compose up -d mongo
MONGO_URL=mongodb://localhost:27017
MONGO_DB=trmission
# Set to 0 to run purely in-memory (no persistence / recovery).
# TRM_PERSISTENCE=0

# Seed a 2-player demo game on boot and log dev tickets for manual smoke play.
# TRM_DEV_GAME=1

# ── Turn pacing & inactivity ──────────────────────────────────────────────────
# Per-turn budget (ms) before the server auto-plays a default action; 0 disables the timer.
# TRM_TURN_TIMEOUT_MS=75000
# Consecutive timed-out human turns before a game is marked inactive and auto-play pauses
# (a lapse with no human socket connected pauses immediately; <=0 disables the streak pause).
# TRM_AUTOPLAY_PAUSE_AFTER=5
# Consecutive timed-out turns for ONE player before — with other humans still connected —
# their seat is handed to a MEDIUM takeover bot (<=0 disables takeover).
# TRM_BOT_TAKEOVER_AFTER=3
# A LIVE game that stays paused (inactive) longer than this many hours is ended by the purge
# sweep via the normal END_GAME path (scored + archived), freeing its room.
# GAME_PAUSED_PURGE_HOURS=24

# ── Auth methods ──────────────────────────────────────────────────────────────
# Each entry method is independently switchable; the web reads GET /auth/config and the
# server enforces these flags (hiding the UI alone is not enough).
# Disable email + password login/registration/upgrade:
# AUTH_PASSWORD_LOGIN_ENABLED=0
# Disable instant guest sessions:
# AUTH_GUEST_ENABLED=0

# ── OAuth (Google + Discord) ──────────────────────────────────────────────────
# A provider is enabled only when BOTH its id and secret are set. Bound by VERIFIED email:
# the same verified email maps to the same account across providers and password login.
#
# Register these exact redirect URIs in each provider's console (dev values shown):
#   Google : http://localhost:5173/api/v1/auth/oauth/google/callback
#   Discord: http://localhost:5173/api/v1/auth/oauth/discord/callback
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# DISCORD_CLIENT_ID=
# DISCORD_CLIENT_SECRET=
#
# Public base URL the browser uses to reach the app. Builds the provider redirect_uri and the
# post-callback web redirect; MUST be the same origin that serves the SPA so the Strict refresh
# cookie is sent on the follow-up /auth/refresh. Defaults to CORS_ORIGINS[0] or the dev web origin.
# OAUTH_REDIRECT_BASE=http://localhost:5173
# Signed-state / nonce-cookie lifetime in ms (the provider round-trip window). Default 10 minutes.
# OAUTH_STATE_TTL_MS=600000

# ── Sign in with Apple ────────────────────────────────────────────────────────
# Native credential path (iOS app): comma list of bundle ids / Services IDs accepted as the
# identity token's audience. Enables POST /auth/oauth/apple/credential.
# APPLE_CLIENT_IDS=dev.robothanzo.trmission
# Web + Android redirect flow: the Apple SERVICES ID used as the OAuth client_id. Register
#   ${OAUTH_REDIRECT_BASE}/api/v1/auth/oauth/apple/callback
# as the Services ID's Return URL in the Apple developer console. Needs the ES256 key material
# below for the code exchange. Unset ⇒ Apple stays native-iOS-only. Note the callback is a
# cross-site form_post: its SameSite=None nonce cookie requires HTTPS (COOKIE_SECURE) — over
# dev http the signed state alone binds the round-trip.
# APPLE_SERVICES_ID=dev.robothanzo.trmission.web
# ES256 signing material (SIWA client_secret JWTs: redirect-flow code exchange + account-deletion
# token revocation). APPLE_PRIVATE_KEY takes literal \n escapes.
# APPLE_TEAM_ID=
# APPLE_KEY_ID=
# APPLE_PRIVATE_KEY=

# ── Maintainer dashboard ──────────────────────────────────────────────────────
# Comma-separated emails granted the `owner` dashboard role at every boot (the accounts
# must already be registered — register first, then restart). All other maintainers are
# managed from the dashboard itself (apps/admin, served at /admin/).
# DASHBOARD_OWNER_EMAILS=you@example.com
