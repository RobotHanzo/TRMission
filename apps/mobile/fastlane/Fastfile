# Self-managed iOS signing + TestFlight delivery — no EAS. `match` pulls certs/profiles from a
# private git repo; `gym` builds the .ipa; `pilot` uploads to TestFlight. An App Store Connect API
# key (ASC_KEY_*) authenticates all three, so no Apple ID password / 2FA is needed anywhere —
# which is load-bearing: no maintainer owns a Mac, so even the read-write `match` seeding runs
# headless in CI (mobile-ios-certs.yml → the :certs lane below).
require "fileutils"

default_platform(:ios)

BUNDLE_ID = "dev.robothanzo.trmission"

def asc_api_key
  app_store_connect_api_key(
    key_id: ENV["ASC_KEY_ID"],
    issuer_id: ENV["ASC_ISSUER_ID"],
    key_content: ENV["ASC_KEY_P8"],
    is_key_content_base64: true
  )
end

# mobile-ios.yml's `pod install` sets RCT_SYMBOLICATE_PREBUILT_FRAMEWORKS=1 so crash symbolication
# keeps working for RN 0.85's prebuilt core/dependency frameworks — but the fetched dSYMs land
# nested INSIDE the vendored .framework bundle itself (Pods/.../React.framework/dSYMs/...) instead
# of alongside it. Left in place, that folder is just another bundle resource by the time Xcode
# codesigns each embedded framework, so it ends up sealed into the framework's own CodeResources
# manifest AND copied into the .app by the Embed Frameworks phase — the latter is what App Store
# Connect rejects at upload ("Invalid bundle structure", ITMS 90171). Stripping it from the
# already-built/signed .ipa (tried first) trades that error for a worse one: punching a hole in an
# already-sealed signature ("Missing or invalid signature", ITMS 90034). Stripping it here instead —
# from the vendored Pods copy, before `gym` ever builds/signs anything — avoids both. This does mean
# RCT_SYMBOLICATE_PREBUILT_FRAMEWORKS can't do its one job (there's no dSYM left for Xcode to seal
# or ship), but a build that can't reach TestFlight isn't a usable trade either; revisit once
# upstream RN stops nesting the dSYM inside the framework it documents alongside. A future RN
# release that fixes the nesting makes this a no-op (glob just finds nothing to strip).
def strip_nested_prebuilt_dsyms
  nested_dsyms = Dir.glob("ios/Pods/**/*.framework/dSYMs")
  return if nested_dsyms.empty?

  UI.important("Stripping #{nested_dsyms.size} nested dSYMs folder(s) out of vendored .framework bundles (RN prebuilt-framework dSYM bug) before gym builds/signs")
  nested_dsyms.each { |d| FileUtils.rm_rf(d) }
end

platform :ios do
  desc "Build the app; upload to TestFlight only with upload:true (mobile-ios.yml passes it on real release tags)"
  lane :beta do |options|
    # GitHub runners boot with the login keychain locked — without a disposable CI keychain,
    # match's cert import prompts (and hangs/fails). No-op outside CI.
    setup_ci if ENV["CI"]

    api_key = asc_api_key

    # Read-only: certs/profiles were provisioned into the match repo by the :certs lane.
    match(type: "appstore", readonly: true, api_key: api_key)

    # `expo prebuild` emits an Automatic-signing project with no team, which xcodebuild rejects
    # for device archives ("requires a development team"). Flip the APP TARGET ONLY to manual
    # signing with the match cert/profile — do not do this via gym xcargs, which would also hit
    # the Pods resource-bundle targets (they can't take a provisioning profile).
    team_id = ENV["APPLE_TEAM_ID"].to_s
    UI.user_error!("APPLE_TEAM_ID must be set (repo variable) — the prebuilt project carries no team id") if team_id.empty?
    profile_name = lane_context[SharedValues::MATCH_PROVISIONING_PROFILE_MAPPING][BUNDLE_ID]
    update_code_signing_settings(
      path: "ios/TRMission.xcodeproj",
      use_automatic_signing: false,
      team_id: team_id,
      code_sign_identity: "Apple Distribution",
      profile_name: profile_name,
      bundle_identifier: BUNDLE_ID,
      targets: ["TRMission"]
    )

    strip_nested_prebuilt_dsyms

    # Workspace/scheme names verified against prebuild's rename logic (@expo/cli
    # renameTemplateAppName: HelloWorld → IOSConfig.XcodeUtils.sanitizedName(name); "TRMission"
    # is already alphanumeric so it passes through unchanged); mobile-ios.yml also asserts the
    # workspace exists right after `pod install` so a template change fails loudly there.
    gym(
      workspace: "ios/TRMission.xcworkspace",
      scheme: "TRMission",
      export_method: "app-store",
      output_directory: "build",
      export_options: {
        provisioningProfiles: { BUNDLE_ID => profile_name }
      }
    )

    if options[:upload]
      pilot(
        api_key: api_key,
        skip_waiting_for_build_processing: true
      )
    else
      # Non-tag runs (workflow_dispatch, release/** pushes) all carry the dev fallback
      # BUILD_NUMBER=1 — TestFlight rejects duplicate build numbers, so they build-only; the
      # .ipa lands in build/ and mobile-ios.yml uploads it as a workflow artifact instead.
      UI.important("upload:false — skipping TestFlight; the .ipa is in build/")
    end
  end

  desc "Seed/rotate the Distribution cert + App Store profile in the match repo (run via mobile-ios-certs.yml — no Mac needed)"
  lane :certs do |options|
    setup_ci if ENV["CI"]
    # readonly:false — creates whatever is missing (cert and/or profile) via the ASC API and
    # pushes it, MATCH_PASSWORD-encrypted, to MATCH_GIT_URL. The App ID must already exist with
    # its capabilities enabled (docs/release/app-store-connect-setup.md Step 2) — match does not
    # create bundle ids. force:true regenerates the profile even if one exists — required after
    # enabling a new capability, since a profile is a snapshot of the App ID's capabilities.
    match(
      type: "appstore",
      readonly: false,
      force: options[:force] || false,
      api_key: asc_api_key
    )
  end
end

# Play publishing via a service-account JSON key (Play Developer API) — no EAS, same self-managed
# posture as iOS. `PLAY_JSON_KEY_FILE` is a decoded-in-CI path (mobile-android.yml); for local runs
# export it yourself. See docs/release/play-console-setup.md for how to provision the key.
#
# CI only ever calls :internal — it never touches the live store listing/images and never
# promotes a track. `metadata`/`promote` are deliberately local-only lanes.
platform :android do
  desc "Upload the signed AAB to Play's internal testing track"
  lane :internal do
    upload_to_play_store(
      track: "internal",
      aab: "android/app/build/outputs/bundle/release/app-release.aab",
      json_key: ENV["PLAY_JSON_KEY_FILE"],
      skip_upload_metadata: true,
      skip_upload_images: true,
      skip_upload_screenshots: true
    )
  end

  desc "Push the committed store listing (fastlane/metadata/android) — run locally, not in CI"
  lane :metadata do
    upload_to_play_store(
      json_key: ENV["PLAY_JSON_KEY_FILE"],
      skip_upload_aab: true,
      skip_upload_apk: true,
      skip_upload_images: true,
      skip_upload_screenshots: true
    )
  end

  desc "Promote the current internal-track build to production — run locally, not in CI"
  lane :promote do
    upload_to_play_store(
      track: "internal",
      track_promote_to: "production",
      json_key: ENV["PLAY_JSON_KEY_FILE"],
      skip_upload_aab: true,
      skip_upload_metadata: true,
      skip_upload_images: true,
      skip_upload_screenshots: true
    )
  end
end
