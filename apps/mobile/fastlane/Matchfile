# Certificates + provisioning profiles live in a private git repo (MATCH_GIT_URL), encrypted with
# MATCH_PASSWORD. Seed it by dispatching the mobile-ios-certs workflow (the :certs lane — headless,
# ASC-API-key auth, no Mac anywhere); the build lane (mobile-ios.yml) consumes it read-only.
git_url(ENV["MATCH_GIT_URL"])
storage_mode("git")
type("appstore")
app_identifier(["dev.robothanzo.trmission"])
