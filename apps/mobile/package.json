{
  "name": "@trm/mobile",
  "version": "0.0.0",
  "private": true,
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "prebuild": "expo prebuild --clean",
    "typecheck": "tsc7 --noEmit",
    "lint": "eslint src",
    "test": "jest",
    "test:pure": "vitest run"
  },
  "dependencies": {
    "@bufbuild/protobuf": "^2.12.1",
    "@formatjs/intl-getcanonicallocales": "^3.2.10",
    "@formatjs/intl-locale": "^5.3.9",
    "@formatjs/intl-pluralrules": "^5.4.4",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/netinfo": "12.0.1",
    "@react-native-google-signin/google-signin": "^15.0.0",
    "@react-navigation/native": "^7.1.6",
    "@react-navigation/native-stack": "^7.3.10",
    "@shopify/react-native-skia": "2.6.2",
    "@trm/client-core": "workspace:*",
    "@trm/codec": "workspace:*",
    "@trm/engine": "workspace:*",
    "@trm/map-data": "workspace:*",
    "@trm/proto": "workspace:*",
    "@trm/shared": "workspace:*",
    "expo": "~56.0.0",
    "expo-apple-authentication": "~56.0.4",
    "expo-audio": "~56.0.12",
    "expo-auth-session": "~56.0.15",
    "expo-build-properties": "~56.0.22",
    "expo-constants": "~56.0.20",
    "expo-crypto": "~56.0.4",
    "expo-haptics": "~56.0.3",
    "expo-linear-gradient": "~56.0.4",
    "expo-linking": "~56.0.15",
    "expo-notifications": "~56.0.19",
    "expo-screen-orientation": "~56.0.5",
    "expo-secure-store": "~56.0.4",
    "expo-splash-screen": "~56.0.12",
    "expo-sqlite": "~56.0.5",
    "expo-status-bar": "~56.0.4",
    "expo-updates": "~56.0.21",
    "expo-web-browser": "~56.0.5",
    "fast-text-encoding": "^1.0.6",
    "i18next": "^24.2.0",
    "immer": "^10.1.1",
    "lucide-react-native": "^1.24.0",
    "react": "19.2.3",
    "react-i18next": "^15.4.0",
    "react-native": "0.85.3",
    "react-native-confetti-cannon": "^1.5.2",
    "react-native-gesture-handler": "~2.31.1",
    "react-native-reanimated": "4.3.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-svg": "15.15.4",
    "react-native-webview": "13.16.1",
    "react-native-worklets": "0.8.3",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@expo/ngrok": "^4.1.0",
    "@react-native/jest-preset": "0.85.3",
    "@testing-library/react-native": "^13.0.0",
    "@trm/tsc7": "workspace:*",
    "@types/jest": "^29.5.12",
    "@types/react": "~19.2.0",
    "eslint": "^9.0.0",
    "jest": "^29.7.0",
    "jest-expo": "~56.0.0",
    "react-test-renderer": "19.2.3",
    "typescript": "npm:@typescript/typescript6@^6.0.2",
    "vitest": "^2.1.8"
  },
  "jest": {
    "preset": "jest-expo",
    "resolver": "<rootDir>/jest.resolver.js",
    "testMatch": [
      "**/*.test.ts",
      "**/*.test.tsx"
    ],
    "testTimeout": 20000,
    "transformIgnorePatterns": [
      "node_modules/(?!(?:.pnpm/)?((jest-)?react-native|@react-native(-community)?|expo(nent)?|@expo(nent)?/.*|@expo-google-fonts/.*|react-navigation|@react-navigation/.*|@bufbuild/.*|@formatjs/.*|@trm/.*|lucide-react-native|react-native-svg|react-native-confetti-cannon))"
    ]
  }
}
