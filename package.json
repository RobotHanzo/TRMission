{
  "name": "trmission",
  "version": "0.0.0",
  "private": true,
  "description": "TRMission (台鐵任務) — multiplayer Taiwan-railway route game",
  "packageManager": "yarn@4.17.1",
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "packages/*",
    "apps/*",
    "tooling/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "lint": "eslint .",
    "test": "turbo run test test:pure",
    "test:engine": "yarn workspace @trm/engine test",
    "format": "prettier --write \"**/*.{ts,tsx,mjs,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,mjs,json,md}\""
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/node": "^22.10.5",
    "eslint": "^9.17.0",
    "prettier": "^3.4.2",
    "turbo": "^2.3.3",
    "typescript": "npm:@typescript/typescript6@^6.0.2",
    "typescript-eslint": "^8.19.1",
    "vitest": "^2.1.8"
  }
}
