      "contributor": null,
      "rationale": "Turn any folder of files into a navigable knowledge graph with community detection, an honest audit trail, and three outputs: interactive HTML, GraphRAG-ready JSON, and a plain-language GRAPH_REPORT.md."
    },
    {
      "id": "_claude_skills_graphify_skill_fast_path",
      "label": "Fast Path (existing graph)",
      "file_type": "rationale",
      "source_file": ".claude/skills/graphify/SKILL.md",
      "source_location": null,
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": null,
      "rationale": "If graphify-out/graph.json exists and the request is a natural-language question about the codebase (not an explicit rebuild command), skip extraction steps entirely and run graphify query directly instead of rebuilding."
    },
