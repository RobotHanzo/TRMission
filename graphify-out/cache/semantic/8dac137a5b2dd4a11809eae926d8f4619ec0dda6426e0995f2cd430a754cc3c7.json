      "source_location": null,
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": null,
      "rationale": "Deterministic, free extraction for code files using graphify.extract.extract; runs in parallel with Part B semantic subagents since AST is fast and needs no LLM."
    },
